<style is:global>
  /* 強制全域字體為標楷體 */
  body, h1, a, button, p {
    font-family: "BiauKai", "標楷體", serif !important;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: linear-gradient(135deg, #a8c0ff, #d1a8ff);
    animation: fadeIn 1s ease-in;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
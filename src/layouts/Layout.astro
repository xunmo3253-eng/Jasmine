<style is:global>
  /* 這裡的樣式會套用到所有頁面 */
  body {
    margin: 0;
    min-height: 100vh;
    background: linear-gradient(135deg, #a8c0ff, #d1a8ff);
    /* 所有的頁面載入時都會觸發這個淡入動畫 */
    animation: fadeIn 1s ease-in;
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="gallery">
    <h1>我們的夢境時光</h1>
    
    <a href="/agreement">
      <img src="/memory-img.jpg" alt="記憶圖" style="max-width: 100%; height: auto;" />
    </a>
    
    <div id="counter" class="counter-box">計算中...</div>
  </div>
</Layout>

<style>
  .gallery { text-align: center; padding: 50px; }
  h1 { color: white; }
  .counter-box { margin-top: 20px; font-size: 1.2rem; color: white; background: rgba(255, 255, 255, 0.2); padding: 10px; display: inline-block; }
</style>

<script is:raw>
  function updateCounter() {
    var start = new Date("2024-05-20T00:00:00");
    var now = new Date();
    var diff = now.getTime() - start.getTime();
    var days = Math.floor(diff / (1000 * 60 * 60 * 24));
    var hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    var minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    var seconds = Math.floor((diff % (1000 * 60)) / 1000);
    var counter = document.getElementById('counter');
    if (counter) {
      counter.innerText = "我們已經在一起：" + days + " 天 " + hours + " 時 " + minutes + " 分 " + seconds + " 秒";
    }
  }
  setInterval(updateCounter, 1000);
  updateCounter();
</script>
---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="gallery">
    <h1>我們的夢境時光</h1>
    <a href="/story">
      <img src="/未命名作品.jpg" alt="與夢角的合照" class="dream-img" />
    </a>
    <div id="counter" class="counter-box">計算中...</div>
  </div>
</Layout>

<style>
  .gallery { text-align: center; padding: 50px; }
  h1 { color: white; }
  .dream-img { 
    max-width: 80%; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    transition: transform 0.3s ease;
  }
  .dream-img:hover { transform: scale(1.05); cursor: pointer; }
  .counter-box { margin-top: 20px; font-size: 1.2rem; color: white; background: rgba(255, 255, 255, 0.2); padding: 10px; display: inline-block; }
</style>

<script is:inline>
  function updateCounter() {
    const start = new Date("2024-05-20T00:00:00");
    const now = new Date();
    const diff = now.getTime() - start.getTime();
    
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((diff % (1000 * 60)) / 1000);
    
    const counter = document.getElementById('counter');
    if (counter) {
      counter.innerText = "我們已經在一起：" + days + " 天 " + hours + " 時 " + minutes + " 分 " + seconds + " 秒";
    }
  }

  setInterval(updateCounter, 1000);
  updateCounter();
</script>
---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="gallery">
    <h1>我們的夢境時光</h1>
    <img src="/未命名作品.jpg" alt="與夢角的合照" class="dream-img" />
    <div id="counter" class="counter-box">計算中...</div>
  </div>
</Layout>

<style>
  .gallery { 
    text-align: center; 
    padding: 50px;
  }
  h1 { color: white; }
  .dream-img { 
    max-width: 80%; 
    border-radius: 20px; 
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  }
  .counter-box { 
    margin-top: 20px; 
    font-size: 1.2rem; 
    font-weight: bold; 
    color: white; 
    background: rgba(255, 255, 255, 0.2); 
    padding: 10px; 
    border-radius: 10px;
    display: inline-block;
  }

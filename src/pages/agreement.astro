---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="content">
    <h1>我們的約定</h1>
    <p>這裡是屬於我們的夢境空間。</p>
    <a href="/Jasmine.memory" style="color: white;">回到上一頁</a>
  </div>
</Layout>

<style>
  .content { text-align: center; padding: 100px; color: white; }
</style>

<style>
  /* 這裡只保留該頁面獨有的樣式 */
  .content { 
    text-align: center; 
    max-width: 600px; 
    padding: 20px; 
    color: white; 
    margin: 0 auto;
    padding-top: 20vh; /* 讓內容稍微往下移一點，避免貼著頂部 */
  }
  .next-btn {
    display: inline-block;
    margin-top: 20px;
    padding: 10px 25px;
    background: white;
    color: #8a70ff;
    border-radius: 30px;
    text-decoration: none;
    font-weight: bold;
    transition: 0.3s;
  }
  .next-btn:hover {
    background: #e0d0ff;
  }
</style>
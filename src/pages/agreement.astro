---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const agreement = await getEntry('rules', 'agreement');

// 如果還是空白，我們直接把錯誤訊息顯示在頁面上
if (!agreement) {
  throw new Error("系統讀不到 agreement.md，請確認路徑為 src/content/rules/agreement.md");
}

const { Content } = await agreement.render();
---

<Layout>
  <div class="content" style="color: white; padding: 50px;">
    <Content />
    <a href="/Jasmine.memory" style="color: cyan;">回到記憶頁</a>
  </div>
</Layout>

<style>
  .content { 
    text-align: center; 
    max-width: 600px; 
    padding-top: 20vh; 
    color: white; 
    margin: 0 auto;
    line-height: 1.8;
  }
  .next-btn {
    display: inline-block;
    margin-top: 20px;
    padding: 10px 25px;
    background: white;
    color: #8a70ff;
    border-radius: 30px;
    text-decoration: none;
    font-weight: bold;
  }
</style>
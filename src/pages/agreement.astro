---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('rules', 'agreement');
const { Content } = await entry.render();
---

<Layout>
  <div class="content">
    <Content />
    <a href="/Jasmine.memory" class="next-btn">我已詳閱規則</a>
  </div>
</Layout>

<style>
  .content { 
    text-align: center; 
    max-width: 600px; 
    padding-top: 20vh; 
    color: white; 
    margin: 0 auto;
    line-height: 1.8;
  }
  .next-btn {
    display: inline-block;
    margin-top: 20px;
    padding: 10px 25px;
    background: white;
    color: #8a70ff;
    border-radius: 30px;
    text-decoration: none;
    font-weight: bold;
    transition: 0.3s;
  }
  .next-btn:hover {
    background: #e0d0ff;
  }
</style>
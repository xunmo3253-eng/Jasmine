---
import Layout from '../layouts/Layout.astro';
// 這裡我們直接引入 Markdown 檔案作為一個模組
import * as AgreementContent from '../content/rules/agreement.md';
---

<Layout>
  <div class="content" style="color: white; padding: 50px;">
    {/* 這裡直接渲染引入的內容 */}
    <AgreementContent.Content />
    <a href="/Jasmine.memory" style="color: cyan;">回到記憶頁</a>
  </div>
</Layout>

<style>
  .content { 
    text-align: center; 
    max-width: 600px; 
    padding-top: 20vh; 
    color: white; 
    margin: 0 auto;
    line-height: 1.8;
  }
  .next-btn {
    display: inline-block;
    margin-top: 20px;
    padding: 10px 25px;
    background: white;
    color: #8a70ff;
    border-radius: 30px;
    text-decoration: none;
    font-weight: bold;
  }
</style>
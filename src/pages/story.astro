---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

// 假設這裡要讀取 my-promise
const entry = await getEntry('promise', 'my-promise');

// 防錯機制：如果讀不到，直接印出明確的錯誤，而不是讓網站崩潰
if (!entry) {
  throw new Error("無法找到 'promise' 集合中的 'my-promise' 檔案，請檢查路徑");
}

const { Content } = await entry.render();
---

<Layout>
  <div class="content">
    <Content />
  </div>
</Layout>

<style>
  .content { 
    text-align: center; 
    max-width: 600px; 
    margin: 0 auto; 
    padding-top: 10vh; 
    color: white; 
    line-height: 1.8;
  }
  .back-link { color: #ffd1dc; font-weight: bold; }
</style>